VITE_API_URL=http://localhost:5000

# ─────────────────────────────────────────────────────────────────────────────
# Module Access Control
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated allowlist of module IDs to enable at startup.
# When unset, ALL modules are enabled by default.
# Available IDs: bi, ypyg, products, upload, audit
#
# Example — enable only Benefit Illustration and Audit Log:
#   VITE_ENABLED_MODULES=bi,audit
#
VITE_ENABLED_MODULES=

# Per-module hard-disable flags.
# Set to "false" or "0" to force-disable a module regardless of
# VITE_ENABLED_MODULES or the user's localStorage settings.
# These cannot be overridden at runtime via the Module Settings panel.
#
# VITE_MODULE_BI=false          # Benefit Illustration
# VITE_MODULE_YPYG=false        # You Pay You Get (formula calculator)
# VITE_MODULE_PRODUCTS=false    # Products & Formulas
# VITE_MODULE_UPLOAD=false      # Bulk Upload
# VITE_MODULE_AUDIT=false       # Audit Log
