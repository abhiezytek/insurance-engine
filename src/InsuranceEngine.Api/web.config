<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <modules>
      <remove name="WebDAVModule" />
    </modules>
    <handlers>
      <remove name="WebDAV" />
      <!-- Remove the default OPTIONS handler so ASP.NET Core CORS middleware handles preflight -->
      <remove name="OPTIONSVerbHandler" />
      <remove name="aspNetCore" />
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <httpProtocol>
      <customHeaders>
        <!-- IIS-level CORS safety net: headers are sent even when the .NET app returns 500 -->
        <add name="Access-Control-Allow-Origin" value="https://insuranceengineui.ezytekapis.com" />
        <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE, OPTIONS" />
        <add name="Access-Control-Allow-Headers" value="Content-Type, Authorization, X-Role" />
      </customHeaders>
    </httpProtocol>
    <aspNetCore processPath="dotnet" arguments=".\InsuranceEngine.Api.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
  </system.webServer>
</configuration>
